# ============================================================================
# HR PRO — Environment Configuration
# Copy this file to ".env" then run: php artisan key:generate
# NEVER commit your real .env file. Keep all secrets out of version control.
# ============================================================================

# --- Application ------------------------------------------------------------
APP_NAME="HR PRO"
APP_ENV=local                       # local | staging | production
APP_KEY=                            # generated by `php artisan key:generate`
APP_DEBUG=true                      # MUST be false in production
APP_TIMEZONE=Asia/Bangkok
APP_URL=http://localhost:8000
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=th_TH

# --- Maintenance / health ---------------------------------------------------
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# --- Logging ----------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug                     # debug in local, warning/error in production

# --- Database (MySQL) -------------------------------------------------------
# Create the schema first:  CREATE DATABASE hr_pro CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hr_pro
DB_USERNAME=root
DB_PASSWORD=

# --- Sessions ---------------------------------------------------------------
# 'file' keeps zero extra infra. Use 'database' or 'redis' for multi-node prod.
SESSION_DRIVER=file
SESSION_LIFETIME=120                # minutes (idle session lifetime)
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false         # MUST be true behind HTTPS in production
SESSION_SAME_SITE=lax

# --- Cache & Queue ----------------------------------------------------------
CACHE_STORE=file
QUEUE_CONNECTION=sync               # use 'redis'/'database' + a worker in prod

# --- Filesystem -------------------------------------------------------------
FILESYSTEM_DISK=local               # employee photos/attachments (local 'public' for served files)

# --- Mail (notifications) ---------------------------------------------------
# 'log' writes emails to storage/logs for local dev. Configure SMTP for prod.
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@hrpro.local"
MAIL_FROM_NAME="${APP_NAME}"

# --- HR PRO domain settings -------------------------------------------------
HRPRO_COMPANY_NAME="HR PRO Co., Ltd."
HRPRO_WORK_START="09:00"            # used to flag late clock-ins
HRPRO_WORK_END="18:00"
HRPRO_LATE_GRACE_MINUTES=15
HRPRO_LEAVE_YEAR_START_MONTH=1      # fiscal/leave year start month (1 = January)
HRPRO_DEFAULT_LOCALE=th
